{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@ciao/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@ciao/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@ciao/engine": [
        "../../packages/engine/src/index.ts"
      ],
      "@ciao/engine/*": [
        "../../packages/engine/src/*"
      ],
      "@ciao/providers": [
        "../../packages/providers/src/index.ts"
      ],
      "@ciao/providers/*": [
        "../../packages/providers/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
